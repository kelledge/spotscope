      "Bash(mount:*)",
      "Bash(umount:*)",
      "Bash(mkswap:*)",
      "Bash(swapoff:*)",
      "Bash(chown:*)",
      "Bash(chmod:*)",
      "Bash(ip route add:*)",
      "Bash(ip route del:*)",
      "Bash(ip route delete:*)",
      "Bash(ip route change:*)",
      "Bash(ip route replace:*)",
